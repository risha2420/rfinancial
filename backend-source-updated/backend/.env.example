# Copy this file to .env and fill in real values before running the server.

# MongoDB Atlas (or any MongoDB) connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/rfinancial?retryWrites=true&w=majority

# Port the API server listens on
PORT=5000

# Comma-separated list of origins allowed to call this API (your deployed frontend URL)
ALLOWED_ORIGINS=http://localhost:5173,https://www.rfinance.in

# Notification email — every form submission is emailed here
NOTIFY_EMAIL=sapan@rfinancial.in

# SMTP settings used to actually send the notification email.
# Works with any provider that exposes SMTP: SendGrid, Amazon SES, Postmark,
# Mailgun, Zoho Mail, Gmail (with an App Password), etc.
# Example for SendGrid: host=smtp.sendgrid.net, port=587, user=apikey, pass=<your API key>
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# "From" address shown on outgoing notification emails (often must be a domain
# you've verified with your SMTP provider). Falls back to SMTP_USER if unset.
MAIL_FROM="R Financial Services <no-reply@rfinancial.in>"
